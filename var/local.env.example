# Windows 側の実データへ var/ から symlink するための設定。
# 使い方: cp var/local.env.example var/local.env してユーザー名を合わせる。
#
# .envrc に次を足すと direnv でも読み込めます（任意）:
#   source_env var/local.env

# Windows のログインユーザー名（WSL の $USER とは別のことが多い）
export VRCTWEAKER_WIN_USER=JO3QMA

# 以下は通常変更不要（フルパスで上書きしたいときだけ設定）
# export VRCTWEAKER_WIN_DATA_DIR=/mnt/c/Users/JO3QMA/AppData/Roaming/vrchat-tweaker
# export VRCTWEAKER_WIN_VRC_LOG_DIR=/mnt/c/Users/JO3QMA/AppData/LocalLow/VRChat/VRChat
