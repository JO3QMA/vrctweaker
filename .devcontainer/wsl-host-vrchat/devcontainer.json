{
  "name": "VRChat Tweaker Dev (WSL → Windows VRChat folders)",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20",
      "pnpmVersion": "latest"
    },
    "ghcr.io/schlich/devcontainer-features/playwright:0": {
      "browsers": "chromium"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "remoteUser": "vscode",
  "initializeCommand": "mkdir -p \"${localEnv:HOME}${localEnv:USERPROFILE}/.config/gh\"",
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.config/gh,target=/home/vscode/.config/gh,type=bind,consistency=cached",
    "source=/mnt/c/Users/${localEnv:USER}/Pictures/VRChat,target=/home/vscode/Pictures/VRChat,type=bind,consistency=cached,readonly",
    "source=/mnt/c/Users/${localEnv:USER}/AppData/LocalLow/VRChat/VRChat,target=/home/vscode/.local/share/VRChat/VRChat,type=bind,consistency=cached"
  ],
  "containerEnv": {
    "GOMODCACHE": "/home/vscode/.gomodcache",
    "GOPATH": "/home/vscode/go",
    "COREPACK_ENABLE_DOWNLOAD_PROMPT": "0",
    "WEBKIT_DISABLE_COMPOSITING_MODE": "1",
    "NO_AT_BRIDGE": "1"
  },
  "postCreateCommand": "bash .devcontainer/postCreate.sh",
  "forwardPorts": [5173, 34115],
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "Vue.volar",
        "qwtel.sqlite-viewer",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
